# Database
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/devflow_db?schema=public"

# GitHub OAuth (Create app at https://github.com/settings/developers)
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_CALLBACK_URL="http://localhost:3001/api/auth/github/callback"

# JWT
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"
JWT_EXPIRES_IN="7d"

# App Configuration
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Webhooks
BACKEND_URL="http://localhost:3001"    # Change to your live API URL in production (e.g. https://api.yourdomain.com)
WEBHOOK_SECRET="change_this_to_a_random_secret"  # Must match the secret set on GitHub webhook

# Optional: For production
# DATABASE_URL="your_production_database_url"
# FRONTEND_URL="https://your-production-domain.com"
# BACKEND_URL="https://api.yourdomain.com"
